        <mxCell id="3c4VYcyDDx7TBEL_XqqJ-70" value="&lt;i&gt;PO&lt;/i&gt; e &lt;i&gt;Tech Lead&lt;/i&gt; descrevem o escopo inicial do Épico, levantando os primeiros requisitos e objetivos das funcionalidades." style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;" parent="3c4VYcyDDx7TBEL_XqqJ-68" vertex="1">
