        <mxCell id="3c4VYcyDDx7TBEL_XqqJ-78" value="&lt;i&gt;Épico&lt;/i&gt; em andamento. As &lt;i&gt;Stories&lt;/i&gt; estão sendo criadas e desenvolvidas sob coordenação do &lt;i&gt;Tech Lead&lt;/i&gt;." style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;" parent="3c4VYcyDDx7TBEL_XqqJ-76" vertex="1">
